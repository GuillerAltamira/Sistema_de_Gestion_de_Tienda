@model TecnoVenta.Models.Venta

<h2>Registrar Venta</h2>

@if(ViewBag.Error != null) 
{
    <p style="color:red">@ViewBag.Error</p>
}
@if(TempData["Success"] != null) 
{
    <p style="color:green">@TempData["Success"]</p>
}


<form method="post">
    <label>ClienteId</label>
    <input type="number" name="ClienteId" required />
    <br/>
    <label>ProductoId</label>
    <input type="number" name="ProductoId" required />
    <br/>
    <label>Cantidad</label>
    <input type="number" name="Cantidad" required />
    <br/>
    <label>Fecha</label>
    <input type="date" name="Fecha" required />
    <br/>
    <label>Total</label>
    <input type="number" step="0.01" name="Total" required />
    <br/>
    <button type="submit">Guardar</button>
</form>
