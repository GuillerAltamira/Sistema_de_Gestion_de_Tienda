@model List<TecnoVenta.Models.Producto>

<h2>Lista de Productos</h2>

<a href="/Productos/Crear">Nuevo Producto</a>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Nombre</th>
        <th>Precio</th>
        <th>Stock</th>
        <th>Acciones</th>
    </tr>

@foreach (var p in Model)
{
<tr>
    <td>@p.Id</td>
    <td>@p.Nombre</td>
    <td>@p.Precio</td>
    <td>@p.Stock</td>

    <td>
        <a href="/Productos/Editar/@p.Id">Editar</a>
        <a href="/Productos/Eliminar/@p.Id">Eliminar</a>
    </td>
</tr>
}

</table>
